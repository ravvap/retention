    {
      "name": "GOV-004 — View and List",
      "item": [
        {
          "name": "AC1 — Get by id → 200 all fields",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const b = pm.response.json();",
              "pm.test('All fields present', () => {",
              "    ['id','name','status','contentType','clockStartTrigger','dispositionAction',",
              "     'createdAt','createdBy','archivePeriodValue','archivePeriodUnit',",
              "     'purgePeriodValue','purgePeriodUnit','activatedAt','retiredAt',",
              "     'description','contentClassification'].forEach(f => pm.expect(b).to.have.property(f));",
              "});",
              "pm.test('Id matches', () => pm.expect(b.id).to.eql(pm.collectionVariables.get('policyId')));",
              "pm.test('View does not mutate state', () => pm.expect(b.retiredAt).to.be.a('string'));"
            ]}
          }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
